# NDTAcademy.com — environment template
# Copy to web/.env.local and fill in. NEVER commit .env.local.

# --- Supabase (project: NDTAcademy / vamjeecpssxhzeyiqqsc) ---
NEXT_PUBLIC_SUPABASE_URL=https://vamjeecpssxhzeyiqqsc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # Settings → API → anon public key
SUPABASE_SERVICE_ROLE_KEY=            # server only — roster admin, certificate issuance, video uploads

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # https://ndtacademy.com in production (canonicals/sitemap/JSON-LD)

# --- Billing (Stripe) ---
STRIPE_SECRET_KEY=                    # sk_test_... ; run scripts/stripe-bootstrap.mjs after setting
STRIPE_WEBHOOK_SECRET=                # whsec_... from stripe listen / bootstrap --webhook
FREE_BETA=true                        # false ⇒ paywall enforced (purchase or org seat required)
FREE_COURSES=vt                       # promo courses free to any signed-in account; "" ends the promo

# --- Media generation (only needed to regenerate course media) ---
ELEVENLABS_API_KEY=                   # voiceovers (scripts/generate-narration.mjs)
ELEVENLABS_VOICE_ID=dtSEyYGNJqjrtBArPCVZ   # "Titan"
OPENAI_API_KEY=                       # gpt-image-2 lesson imagery (scripts/generate-images.mjs)
